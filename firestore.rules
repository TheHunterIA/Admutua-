rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "cleitonprado003@gmail.com" && request.auth.token.email_verified == true);
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Publicly readable configuration and content
    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /departments/{deptId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /congregations/{congId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Contact submissions: Public can create, only admin can read/delete
    match /contactSubmissions/{subId} {
      allow create: if true;
      allow read, delete: if isAdmin();
      allow update: if false;
    }

    match /updates/{updateId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /ebdLessons/{lessonId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /ebdClasses/{classId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /missionaries/{missionaryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
